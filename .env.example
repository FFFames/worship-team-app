# WorshipTeam Environment Variables
# The app uses localStorage for data persistence, no backend required.

# Optional: For future Supabase integration
# VITE_SUPABASE_URL=your-project-url
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Function secret (set with Supabase CLI, not VITE_)
# supabase secrets set GROQ_API_KEY=your-groq-api-key
